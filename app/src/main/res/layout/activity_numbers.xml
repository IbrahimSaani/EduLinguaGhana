<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground"
    tools:context=".NumbersActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_background"
        android:elevation="8dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            app:title="@string/numbers_mode"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Section with Counter and Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:spacing="16dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- Animated Progress Counter with Enhanced Design -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/colorAccent"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/colorPrimary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:spacing="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔢"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:spacing="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Progress"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:alpha="0.8" />

                            <TextView
                                android:id="@+id/tvProgressCounter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Number 1 of 50"
                                android:textColor="@android:color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/agbalumo" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📊"
                                android:textSize="24sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced SeekBar Section with better styling -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/ripple_card_effect"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:spacing="8dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/colorAccent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Navigation"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:alpha="0.8" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarNavigation"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:max="99"
                        android:progress="0"
                        android:progressBackgroundTint="@color/buttonSecondary"
                        android:progressTint="@color/colorAccent"
                        android:thumbTint="@color/colorPrimary"
                        android:scaleY="1.2" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Slide smoothly to jump between numbers"
                        android:textColor="@color/textColorSecondary"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:alpha="0.75" />
                </LinearLayout>

                <!-- Progress Bar with Enhanced Visual -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <ImageView
                        android:id="@+id/progressIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_progress_sparkle"
                        app:tint="@color/colorAccent" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_toEndOf="@id/progressIcon"
                        android:progress="0"
                        app:indicatorColor="@color/colorAccent"
                        app:trackColor="@color/buttonSecondary"
                        app:trackCornerRadius="6dp"
                        app:trackThickness="12dp" />
                </RelativeLayout>

                <!-- Quick Access Grid and Picker Button with Enhanced Styling -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:spacing="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShowPicker"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="🔢 Grid"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:elevation="6dp"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconSize="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSpeakQuick"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:text="🎤 Speak"
                        android:textSize="13sp"
                        app:cornerRadius="14dp"
                        app:strokeWidth="2dp"
                        app:icon="@drawable/ic_speak"
                        app:iconSize="20dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="12dp"
                android:layout_marginBottom="28dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/numberCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="@color/colorAccent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.08"
                        android:background="@drawable/bg_splash_gradient" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical"
                        android:spacing="20dp">

                        <!-- Language emoji -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="8dp"
                            app:cardBackgroundColor="@color/colorAccent">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🌍"
                                android:textSize="32sp"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:spacing="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Language"
                                android:textColor="@color/textColorSecondary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/tvLanguageTitleNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/language_prefix"
                                android:textColor="@color/colorPrimary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/agbalumo" />

                            <TextView
                                android:id="@+id/tvModeLabelNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/numbers_mode"
                                android:textColor="@color/colorAccent"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Numbers emoji -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="8dp"
                            app:cardBackgroundColor="@color/colorPrimary">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🔢"
                                android:textSize="32sp"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mode Badge - Shows RECITAL or PRACTICE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/modeBadgeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:spacing="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/modeBadgeIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔢"
                            android:textSize="20sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:spacing="2dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Current Mode"
                                android:textColor="@color/colorPrimary"
                                android:textSize="10sp"
                                android:alpha="0.7" />

                            <TextView
                                android:id="@+id/modeBadgeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RECITAL"
                                android:textColor="@color/colorPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/modeBadgeDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Listen &amp; Learn"
                            android:textColor="@color/textColorSecondary"
                            android:textSize="11sp"
                            android:alpha="0.8"
                            android:layout_marginEnd="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrevNumber"
                    style="@style/Widget.Material3.Button.ElevatedButton.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/content_description_previous"
                    app:cornerRadius="36dp"
                    app:elevation="14dp"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconGravity="textStart"
                    app:iconSize="36dp"
                    app:iconPadding="0dp"
                    app:backgroundTint="@color/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/btnNextNumber"
                    android:layout_toEndOf="@id/btnPrevNumber"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="16dp"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="4dp">

                    <!-- Gradient background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.1"
                        android:background="@drawable/bg_splash_gradient" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="40dp">

                        <!-- Emoji decoration -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp">

                            <TextView
                                android:id="@+id/celebrationEmoji"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎉"
                                android:textSize="48sp" />
                        </FrameLayout>

                        <!-- Main number with glow effect -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="36dp">

                            <!-- Glow effect -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/agbalumo"
                                android:text="1"
                                android:alpha="0.15"
                                android:textColor="@color/colorAccent"
                                android:textSize="150sp"
                                android:textStyle="bold" />

                            <!-- Main number -->
                            <TextView
                                android:id="@+id/tvNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/agbalumo"
                                android:text="1"
                                android:textColor="@color/colorAccent"
                                android:textSize="150sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <!-- Number spelling with enhanced styling -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="36dp"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:spacing="12dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:spacing="6dp"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📝"
                                    android:textSize="16sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Number Spelling"
                                    android:textColor="@color/textColorSecondary"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:alpha="0.75" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvNumberSpelling"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorPrimary"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/agbalumo"
                                android:letterSpacing="0.05"
                                android:gravity="center"
                                android:maxLines="4"
                                android:ellipsize="end"
                                tools:text="One" />
                        </LinearLayout>

                        <!-- Speak button - Enhanced -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSpeakNumber"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="68dp"
                            android:minWidth="240dp"
                            android:paddingStart="36dp"
                            android:paddingEnd="36dp"
                            android:text="@string/speak_button"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:cornerRadius="34dp"
                            app:elevation="10dp"
                            app:icon="@drawable/ic_speak"
                            app:iconSize="28dp"
                            app:iconGravity="start"
                            app:iconPadding="16dp" />

                        <!-- Hint text -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="✨ Tap to hear pronunciation!"
                            android:textColor="@color/colorAccent"
                            android:textSize="11sp"
                            android:alpha="0.75"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextNumber"
                    style="@style/Widget.Material3.Button.ElevatedButton.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/content_description_next"
                    app:cornerRadius="36dp"
                    app:elevation="14dp"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconGravity="textStart"
                    app:iconSize="36dp"
                    app:iconPadding="0dp"
                    app:backgroundTint="@color/colorPrimary" />

            </RelativeLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnBackNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/content_description_back"
        app:srcCompat="@drawable/ic_back_fab" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>