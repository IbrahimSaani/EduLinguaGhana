<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rocketSortRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Deep Space Background Layer -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_game_rocket_modern" />

    <!-- Scrolling Star Field -->
    <FrameLayout
        android:id="@+id/starFieldContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Tech HUD Bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_hud_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/agbalumo"
                android:text="⭐ 0"
                android:textColor="#4FC3F7"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/agbalumo"
                android:text="⏱️ 60s"
                android:textColor="#4FC3F7"
                android:textSize="22sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvLives"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/agbalumo"
                android:text="❤️ ❤️ ❤️ ❤️ ❤️"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <ImageButton
                android:id="@+id/btnPause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Pause"
                android:src="@drawable/ic_pause"
                app:tint="#4FC3F7" />
        </LinearLayout>

        <!-- Game Area -->
        <FrameLayout
            android:id="@+id/asteroidContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/rocketDock"
            android:layout_below="@+id/topBar" />

        <!-- Rocket Docking Station -->
        <LinearLayout
            android:id="@+id/rocketDock"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_rocket_dock"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:paddingBottom="20dp">

            <FrameLayout
                android:id="@+id/rocketLetters"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|top"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/agbalumo"
                    android:text="@string/rocket_sort_letters"
                    android:textColor="#FFAB40"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivRocketLeft"
                    android:layout_width="90dp"
                    android:layout_height="130dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:src="@drawable/ic_rocket" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/rocketNumbers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|top"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/agbalumo"
                    android:text="@string/rocket_sort_numbers"
                    android:textColor="#4FC3F7"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivRocketRight"
                    android:layout_width="90dp"
                    android:layout_height="130dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:src="@drawable/ic_rocket" />
            </FrameLayout>
        </LinearLayout>

        <!-- Start Countdown Overlay -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/agbalumo"
            android:text="3"
            android:textColor="#4FC3F7"
            android:textSize="120sp"
            android:visibility="gone"
            android:shadowColor="#000000"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="10" />

        <!-- Overlay Menu -->
        <LinearLayout
            android:id="@+id/overlayLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#CC1A1E29"
                app:cardCornerRadius="32dp"
                app:cardElevation="24dp"
                app:strokeColor="#4FC3F7"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/tvOverlayTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/agbalumo"
                        android:text="Game Over"
                        android:textColor="#4FC3F7"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOverlayScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Final Score: 0"
                        android:textColor="@color/white"
                        android:textSize="22sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#4FC3F7"
                        android:padding="16dp"
                        android:text="Resume Mission"
                        android:textColor="#0D1117"
                        android:visibility="gone"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRestart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#FFAB40"
                        android:padding="16dp"
                        android:text="Play Again"
                        android:textColor="#0D1117"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuit"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Quit Mission"
                        android:textColor="#4FC3F7" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </RelativeLayout>

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
