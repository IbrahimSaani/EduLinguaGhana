<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tutorialRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Dynamic Background Layer -->
    <View
        android:id="@+id/viewBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_background_light" />

    <!-- Animated Shapes Layer (for "Liveness") -->
    <FrameLayout
        android:id="@+id/animatedShapesContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <!-- Letters -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A" android:textSize="32sp" android:textColor="@color/colorPrimary" android:alpha="0.2" android:layout_marginTop="80dp" android:layout_marginStart="40dp" android:fontFamily="@font/agbalumo" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B" android:textSize="40sp" android:textColor="@color/colorPrimary" android:alpha="0.15" android:layout_marginTop="450dp" android:layout_marginStart="20dp" android:fontFamily="@font/agbalumo" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:textSize="28sp" android:textColor="@color/colorPrimary" android:alpha="0.2" android:layout_marginTop="200dp" android:layout_marginStart="320dp" android:fontFamily="@font/agbalumo" />

        <!-- Numbers -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textSize="36sp" android:textColor="@color/colorAccent" android:alpha="0.2" android:layout_marginTop="600dp" android:layout_marginStart="50dp" android:fontFamily="@font/agbalumo" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textSize="44sp" android:textColor="@color/colorAccent" android:alpha="0.15" android:layout_marginTop="150dp" android:layout_marginStart="280dp" android:fontFamily="@font/agbalumo" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="30sp" android:textColor="@color/colorAccent" android:alpha="0.2" android:layout_marginTop="750dp" android:layout_marginStart="300dp" android:fontFamily="@font/agbalumo" />

        <!-- Shapes -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✨" android:textSize="24sp" android:layout_marginTop="350dp" android:layout_marginStart="150dp" android:alpha="0.3" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭕" android:textSize="30sp" android:layout_marginTop="50dp" android:layout_marginStart="200dp" android:alpha="0.2" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="20sp" android:layout_marginTop="680dp" android:layout_marginStart="180dp" android:alpha="0.3" />
    </FrameLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerTutorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/layoutBottom"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Progress Indicator at Top -->
    <ProgressBar
        android:id="@+id/progressBarTutorial"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:progressDrawable="@drawable/progress_splash_track"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@android:color/transparent"
            app:tabBackground="@drawable/tab_selector"
            app:tabIndicatorHeight="0dp"
            app:tabMaxWidth="12dp"
            app:tabRippleColor="@android:color/transparent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:fontFamily="@font/agbalumo"
            android:text="Next"
            android:textSize="18sp"
            android:elevation="6dp"
            android:textColor="@color/white"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Skip Tutorial"
            android:textColor="@color/textColorSecondary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
