<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".QuizActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_background"
        android:elevation="8dp"
        android:visibility="gone"
        tools:visibility="visible"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            app:title="@string/quiz_title"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Start Screen -->
        <ScrollView
            android:id="@+id/startQuizContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="40dp">

                <!-- Welcome Icon with Animation -->
                <ImageView
                    android:id="@+id/ivWelcomeIcon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/quiz_welcome"
                    tools:src="@drawable/ic_quiz_letters" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardElevation="8dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/colorAccent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:background="@color/cardBackground">

                        <TextView
                            android:id="@+id/tvStartTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:fontFamily="@font/agbalumo"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceHeadline4"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            tools:text="Letters Quiz" />

                        <TextView
                            android:id="@+id/tvStartDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceBody1"
                            android:textColor="@color/textColorSecondary"
                            android:lineSpacingMultiplier="1.2"
                            tools:text="Listen carefully to the audio and tap the correct letter. You have 30 seconds. Good luck! 🎯" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats Preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardElevation="4dp"
                        app:cardCornerRadius="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⏱️"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/quiz_time_limit"
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textColor="@color/textColorSecondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="30s"
                                android:textAppearance="?attr/textAppearanceHeadline6"
                                android:textColor="@color/colorPrimary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardElevation="4dp"
                        app:cardCornerRadius="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎯"
                                android:textSize="28sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/quiz_mode"
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textColor="@color/textColorSecondary" />

                            <TextView
                                android:id="@+id/tvStartMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textAppearance="?attr/textAppearanceHeadline6"
                                android:textColor="@color/colorAccent"
                                tools:text="Letters" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Colorful Start Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/quiz_start_button"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/colorAccent"
                    android:textColor="@color/white"
                    app:elevation="8dp"
                    android:contentDescription="@string/quiz_start_button" />

            </LinearLayout>
        </ScrollView>


        <!-- Quiz Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/quizContentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingTop="20dp">

                <!-- Enhanced Stats Card with Progress -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@color/cardBackground">

                        <!-- Progress Bar -->
                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:progress="50"
                            android:layout_marginBottom="16dp"
                            android:clipToOutline="true" />

                        <!-- Stats Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏰"
                                    android:textSize="24sp" />

                                <TextView
                                    android:id="@+id/tvTimer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="?attr/textAppearanceBody2"
                                    android:textColor="@color/colorPrimary"
                                    android:textStyle="bold"
                                    tools:text="30s" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⭐"
                                    android:textSize="24sp" />

                                <TextView
                                    android:id="@+id/tvScore"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="?attr/textAppearanceBody2"
                                    android:textColor="@color/colorAccent"
                                    android:textStyle="bold"
                                    tools:text="0" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏆"
                                    android:textSize="24sp" />

                                <TextView
                                    android:id="@+id/tvBest"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="?attr/textAppearanceBody2"
                                    android:textColor="@color/correctAnswer"
                                    android:textStyle="bold"
                                    tools:text="0" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Prompt Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardElevation="8dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="@color/colorAccent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center"
                        android:background="@color/cardBackground">

                        <TextView
                            android:id="@+id/tvGamePrompt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceHeadline4"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:lineSpacingMultiplier="1.3"
                            tools:text="Listen carefully!\nWhich letter did you hear?" />

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/btnPlayAudio"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginTop="16dp"
                            android:contentDescription="@string/quiz_play_audio_description"
                            app:srcCompat="@drawable/ic_play_audio"
                            app:elevation="6dp"
                            android:backgroundTint="@color/colorAccent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Tap to play audio"
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:textColor="@color/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Interactive Options Grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="3"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption1"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="A" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption2"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption3"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="C" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption4"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="D" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption5"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOption6"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:minHeight="64dp"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        android:letterSpacing="0.1"
                        tools:text="F" />

                </GridLayout>

                <!-- Animated Feedback -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardElevation="4dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFeedback"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceHeadline5"
                            android:textStyle="bold"
                            android:minHeight="40dp"
                            android:layout_gravity="center"
                            tools:text="✅ Correct! Great job!" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- End Screen with Celebration -->
        <LinearLayout
            android:id="@+id/endQuizContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Celebration Animation -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieAnimationView"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/kids_animation" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardElevation="8dp"
                app:cardCornerRadius="16dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/colorAccent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="@color/cardBackground">

                    <TextView
                        android:id="@+id/tvEndTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/agbalumo"
                        android:gravity="center"
                        android:text="@string/quiz_end_title"
                        android:textAppearance="?attr/textAppearanceHeadline3"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNewHighScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/agbalumo"
                        android:gravity="center"
                        android:text="@string/quiz_end_new_high_score"
                        android:textAppearance="?attr/textAppearanceHeadline5"
                        android:textColor="@color/colorAccent"
                        android:visibility="gone"
                        android:textStyle="bold"
                        tools:visibility="visible" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="12dp"
                        app:cardElevation="4dp"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/colorAccent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Score"
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textColor="@color/textColorSecondary" />

                            <TextView
                                android:id="@+id/tvFinalScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:textAppearance="?attr/textAppearanceHeadline3"
                                android:textColor="@color/colorAccent"
                                android:textStyle="bold"
                                tools:text="12" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardElevation="4dp"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/correctAnswer">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Best Score"
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textColor="@color/textColorSecondary" />

                            <TextView
                                android:id="@+id/tvEndBestScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:textAppearance="?attr/textAppearanceHeadline3"
                                android:textColor="@color/correctAnswer"
                                android:textStyle="bold"
                                tools:text="15" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlayAgain"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/quiz_play_again_button"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/colorAccent"
                    android:textColor="@color/white"
                    app:elevation="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEndQuit"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/quiz_quit_button"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="2dp"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

