<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/questCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dividerColor"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Quest Icon with Status Indicator -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp">

            <!-- Icon Background -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/iconBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F5F5F5">

                <View
                    android:id="@+id/overlayColor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/colorPrimaryLight"
                    android:alpha="0.15" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Quest Icon / Emoji -->
            <TextView
                android:id="@+id/tv_quest_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="32sp"
                android:gravity="center"
                android:elevation="2dp"
                tools:text="⚡" />

            <!-- Completion Checkmark (for completed quests) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/completionIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/correctAnswer"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="✓"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Quest Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Quest Title -->
            <TextView
                android:id="@+id/tv_quest_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Complete 5 Quizzes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Quest Description (optional) -->
            <TextView
                android:id="@+id/tv_quest_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Test your knowledge"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                android:layout_marginBottom="6dp" />

            <!-- Quest Progress Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_quest"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:indicatorColor="@color/colorPrimary"
                    app:trackColor="@color/progressTrackColor"
                    app:trackCornerRadius="3dp"
                    app:trackThickness="6dp"
                    tools:progress="60" />

                <TextView
                    android:id="@+id/tv_quest_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="3/5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

            </LinearLayout>

            <!-- Ready to Claim Indicator -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/claimIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/correctAnswer">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ Tap to Claim"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Quest Points Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF8E1">

                <TextView
                    android:id="@+id/tv_quest_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    tools:text="+50 XP"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#F57C00" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Right Arrow (Indicator for progress) -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_forward"
            android:contentDescription="Quest Progress Indicator"
            app:tint="@color/dividerColor"
            android:alpha="0.5" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
