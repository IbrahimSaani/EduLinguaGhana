<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/questCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dividerColor"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Quest Icon with Status Indicator -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="14dp">

            <!-- Icon Background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_background"
                android:alpha="0.15" />

            <!-- Quest Icon / Emoji -->
            <TextView
                android:id="@+id/tv_quest_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="⚡"
                android:textSize="32sp"
                android:gravity="center"
                tools:text="⚡" />

            <!-- Completion Checkmark (for completed quests) -->
            <view
                android:id="@+id/completionCheckmark"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-4dp"
                android:layout_marginBottom="-4dp"
                android:background="@drawable/circle_background"
                android:visibility="gone" />

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="-4dp"
                android:layout_marginBottom="-4dp"
                android:text="✓"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Quest Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Quest Title -->
            <TextView
                android:id="@+id/tv_quest_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Complete 5 Quizzes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Quest Description (optional) -->
            <TextView
                android:id="@+id/tv_quest_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Test your knowledge"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                android:layout_marginBottom="6dp" />

            <!-- Quest Progress Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_quest"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:indicatorColor="@color/colorPrimary"
                    app:trackColor="@color/progressTrackColor"
                    app:trackCornerRadius="3dp"
                    app:trackThickness="6dp"
                    tools:progress="60" />

                <TextView
                    android:id="@+id/tv_quest_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="3/5"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

            </LinearLayout>

            <!-- Ready to Claim Indicator -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/claimIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/correctAnswer">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ Tap to Claim"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Quest Points Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="12dp"
            android:background="@drawable/badge_background"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_quest_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="+50"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/colorAccent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XP"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

