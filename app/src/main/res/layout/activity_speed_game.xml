<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- THE GAME BACKGROUND LAYER -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_speed_game_modern"
        android:scaleType="centerCrop"
        android:contentDescription="Background" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white"
            app:title="Speed Challenge"
            app:titleTextAppearance="@style/ToolbarTitleStyle"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="8dp">

            <!-- Tech HUD Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_hud_panel"
                android:orientation="vertical"
                android:padding="16dp">

                <ProgressBar
                    android:id="@+id/speedProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginBottom="16dp"
                    android:progress="100"
                    android:progressTint="#FFAB40"
                    android:backgroundTint="#44FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvGameTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/agbalumo"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="30s" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIME"
                            android:textColor="#88FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvGameScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/agbalumo"
                            android:textColor="#FFD54F"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            tools:text="15" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SCORE"
                            android:textColor="#88FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvGameBest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/agbalumo"
                            android:textColor="#4DB6AC"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="42" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BEST"
                            android:textColor="#88FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Modern Question Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#F5F5FA"
                app:strokeWidth="4dp"
                app:strokeColor="#FFAB40">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvGamePrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:fontFamily="@font/agbalumo"
                        android:textColor="@color/colorPrimary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2"
                        tools:text="Listen carefully!\nTap the correct letter" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnPlayAudio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:contentDescription="Play Audio"
                        app:srcCompat="@drawable/ic_play_audio"
                        app:backgroundTint="#FFAB40"
                        app:tint="@color/white"
                        app:elevation="8dp" />

                    <com.edulinguaghana.ShadowView
                        android:id="@+id/shadowView"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvGameFeedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/agbalumo"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:minHeight="32dp"
                        tools:text="✅ Great job!" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Game Options Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt1"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="A" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt2"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="B" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt3"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="C" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt4"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="D" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt5"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="E" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGameOpt6"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/agbalumo"
                    android:backgroundTint="#1A237E"
                    app:strokeWidth="2dp"
                    app:strokeColor="#4FC3F7"
                    app:cornerRadius="20dp"
                    tools:text="F" />
            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGameBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Quit Mission"
                android:backgroundTint="#44000000"
                android:textColor="#FFFFFF"
                app:strokeWidth="1.5dp"
                app:strokeColor="#4FC3F7"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
