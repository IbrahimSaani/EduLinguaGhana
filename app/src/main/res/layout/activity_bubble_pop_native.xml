<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gameRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Sky Background Layer -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_bubble_game_modern" />

    <com.edulinguaghana.DynamicBackgroundView
        android:id="@+id/dynamicBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Ambient Particles -->
    <FrameLayout
        android:id="@+id/ambientParticles"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <RelativeLayout
        android:id="@+id/gameContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <!-- Professional Stats Bar -->
        <LinearLayout
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_hud_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/agbalumo"
                android:text="⭐ 0"
                android:textColor="#4FC3F7"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/agbalumo"
                android:text="60s"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Target Letter Display -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTargetLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POP THIS!"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTarget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/agbalumo"
                    android:text="A"
                    android:textColor="#FFAB40"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowRadius="5"
                    android:shadowDx="2"
                    android:shadowDy="2"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Game Area -->
        <FrameLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="120dp"
            android:clipChildren="false" />

        <!-- Countdown Overlay -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/agbalumo"
            android:text="3"
            android:textColor="#FF4081"
            android:textSize="120sp"
            android:visibility="gone"
            android:shadowColor="#000000"
            android:shadowRadius="10" />

        <!-- Overlay Menu -->
        <LinearLayout
            android:id="@+id/overlayLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F5F5FA"
                app:cardCornerRadius="32dp"
                app:cardElevation="24dp"
                app:strokeColor="#FF4081"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvOverlayTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Game Over!"
                        android:textColor="#FF4081"
                        android:textSize="36sp"
                        android:fontFamily="@font/agbalumo"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOverlayScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Final Score: 0"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="22sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#4FC3F7"
                        android:padding="16dp"
                        android:text="Resume Game"
                        android:textColor="#0D1117"
                        android:visibility="gone"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRestart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#FF4081"
                        android:text="Play Again"
                        android:padding="16dp"
                        app:cornerRadius="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQuit"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Back to Menu"
                        android:textColor="@color/textColorSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <nl.dionsegijn.konfetti.xml.KonfettiView
            android:id="@+id/konfettiView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </RelativeLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
