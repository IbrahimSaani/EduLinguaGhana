<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Playful Purple Gradient -->
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#FF4527A0"
                android:centerColor="#FF512DA8"
                android:endColor="#FF673AB7" />
        </shape>
    </item>

    <!-- Geometric Pattern Overlay -->
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF"
                android:dashWidth="60dp"
                android:dashGap="40dp" />
        </shape>
    </item>
</layer-list>