<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Space Gradient -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#0F1420"
                android:startColor="#1A237E" />
        </shape>
    </item>

    <!-- Tech Grid Overlay (Simulated with a stroke) -->
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- Ground / Launchpad Area -->
    <item android:top="500dp">
        <shape>
            <solid android:color="#263238" />
        </shape>
    </item>
</layer-list>
