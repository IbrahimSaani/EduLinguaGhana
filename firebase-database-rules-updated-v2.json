{
  "rules": {
    "leaderboard": {
      ".read": true,
      ".indexOn": ["score", "timestamp"],
      "$userId": {
        ".read": true,
        ".write": "$userId === auth.uid",
        ".validate": "newData.hasChildren(['score', 'userName']) && newData.child('score').isNumber() && newData.child('userName').isString()"
      }
    },
    "users": {
      ".read": "auth != null",
      ".indexOn": ["email", "username", "role"],
      "$userId": {
        ".write": "$userId === auth.uid",
        ".read": true,
        "role": {
          ".write": "$userId === auth.uid",
          ".validate": "newData.isString() && (newData.val() === 'STUDENT' || newData.val() === 'TEACHER' || newData.val() === 'PARENT')"
        },
        "fcmToken": {
          ".write": "$userId === auth.uid",
          ".validate": "newData.isString()"
        },
        "displayName": {
          ".write": "$userId === auth.uid"
        },
        "badges": {
          ".write": "$userId === auth.uid"
        },
        "quests": {
          ".write": "$userId === auth.uid"
        },
        "achievements": {
          ".write": "$userId === auth.uid"
        }
      }
    },
    "friends": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["userId", "friendUserId", "status"]
    },
    "challenges": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["state", "challengedId", "challengerId", "completedAt", "createdAt"],
      "$challengeId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['challengerId', 'challengedId', 'state']) && newData.child('state').isString() && (newData.child('state').val() === 'pending' || newData.child('state').val() === 'in_progress' || newData.child('state').val() === 'completed' || newData.child('state').val() === 'PENDING' || newData.child('state').val() === 'ONGOING' || newData.child('state').val() === 'COMPLETED' || newData.child('state').val() === 'EXPIRED' || newData.child('state').val() === 'CANCELLED') && newData.child('challengerId').isString() && newData.child('challengedId').isString() && newData.child('createdAt').isNumber() && newData.child('language').isString() && newData.child('quizType').isString() && newData.child('durationMinutes').isNumber()",
        "challengerScore": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "challengedScore": {
          ".validate": "newData.isNumber() || !newData.exists()"
        },
        "winnerId": {
          ".validate": "newData.isString() || !newData.exists()"
        }
      }
    },
    "challengeStats": {
      ".read": "auth != null",
      ".indexOn": ["userId", "winRate", "totalChallenges"],
      "$userId": {
        ".read": "auth != null",
        ".write": "$userId === auth.uid || auth != null",
        ".validate": "newData.hasChildren(['userId', 'challengesWon', 'challengesLost', 'challengesTied', 'totalChallenges', 'winRate']) && newData.child('userId').val() === $userId && newData.child('challengesWon').isNumber() && newData.child('challengesLost').isNumber() && newData.child('challengesTied').isNumber() && newData.child('totalChallenges').isNumber() && newData.child('winRate').isNumber()",
        "challengesWon": {
          ".validate": "newData.isNumber()"
        },
        "challengesLost": {
          ".validate": "newData.isNumber()"
        },
        "challengesTied": {
          ".validate": "newData.isNumber()"
        },
        "totalChallenges": {
          ".validate": "newData.isNumber()"
        },
        "winRate": {
          ".validate": "newData.isNumber()"
        },
        "lastChallengeTime": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "relationships": {
      ".read": "auth != null",
      ".indexOn": ["supervisorId", "studentId", "status"],
      "$relationshipId": {
        ".read": "auth != null",
        ".write": "auth != null && (data.child('supervisorId').val() === auth.uid || data.child('studentId').val() === auth.uid || !data.exists())",
        ".validate": "newData.hasChildren(['supervisorId', 'studentId', 'status', 'type']) || !newData.exists()"
      }
    },
    "progress": {
      ".read": "auth != null",
      ".indexOn": ["userId"],
      "$userId": {
        ".read": "$userId === auth.uid || auth != null",
        ".write": "$userId === auth.uid",
        "activities": {
          ".read": "$userId === auth.uid || auth != null",
          ".write": "$userId === auth.uid",
          ".indexOn": ["timestamp"],
          "$activityId": {
            ".read": "$userId === auth.uid || auth != null",
            ".write": "$userId === auth.uid"
          }
        }
      }
    },
    "aggregates": {
      ".read": "auth != null",
      ".indexOn": ["userId"],
      "$userId": {
        ".read": "$userId === auth.uid || auth != null",
        ".write": "$userId === auth.uid"
      }
    },
    "achievement_shares": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["userId", "timestamp"]
    },
    "milestones": {
      ".read": "auth != null",
      ".indexOn": ["userId"],
      "$userId": {
        ".read": "auth != null",
        ".write": "$userId === auth.uid",
        "$milestoneId": {
          ".read": "$userId === auth.uid || auth != null",
          ".write": "$userId === auth.uid"
        }
      }
    },
    "userStats": {
      ".read": "auth != null",
      ".indexOn": ["userId"],
      "$userId": {
        ".read": "$userId === auth.uid || auth != null",
        ".write": "$userId === auth.uid"
      }
    }
  }
}
